<Window x:Class="PicViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PicViewer"
        mc:Ignorable="d"
        Title="PicViewer" Height="700" Width="1100" Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel>
        <!-- 頂端選單列 (Menu Bar) -->
        <Menu x:Name="TopMenuBar" DockPanel.Dock="Top" Background="#2D2D30" Foreground="#E0E0E0" Padding="2">
            <!-- 簡單深色樣式設定 -->
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </Menu.Resources>
            
            <MenuItem Header="{DynamicResource Menu_File}" Foreground="#E0E0E0">
                <MenuItem Header="{DynamicResource Menu_Exit}" Click="MenuExit_Click" />
            </MenuItem>
            
            <MenuItem Header="{DynamicResource Menu_View}" Foreground="#E0E0E0">
                <MenuItem Header="{DynamicResource Menu_FilterSettings}" Click="MenuFormatFilter_Click" />
                <Separator Background="#3E3E42" Foreground="#333" />
                <MenuItem Header="{DynamicResource Menu_ActualSize}" />
                <MenuItem Header="{DynamicResource Menu_ZoomIn}" />
                <MenuItem Header="{DynamicResource Menu_ZoomOut}" />
            </MenuItem>
            
            <MenuItem x:Name="MenuLanguageRoot" Header="{DynamicResource Menu_Language}" Foreground="#E0E0E0">
                <!-- Languages will be added here dynamically -->
            </MenuItem>
            
            <MenuItem Header="{DynamicResource Menu_Help}" Foreground="#E0E0E0">
                <MenuItem Header="{DynamicResource Menu_About}" Click="MenuAbout_Click" />
            </MenuItem>
        </Menu>

        <!-- 狀態列 (StatusBar) -->
        <StatusBar x:Name="BottomStatusBar" DockPanel.Dock="Bottom" Background="#007ACC" Foreground="White" Padding="5,2">
            <!-- 靠右對齊的縮放比例顯示 -->
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource StatusBar_ZoomRatio}" />
                    <!-- 使用 Binding 動態顯示 MainImageScale 的 ScaleX 值，並格式化為百分比 -->
                    <TextBlock Text="{Binding ElementName=MainImageScale, Path=ScaleX, StringFormat={}{0:P0}}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 原本的排版主體 (自動填滿 DockPanel 下方剩餘空間) -->
        <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <!-- 左側的樹狀目錄面板 -->
            <ColumnDefinition x:Name="LeftColDef" Width="280" />
            <ColumnDefinition x:Name="SplitterColDef" Width="5" />
            <!-- 右側的主要看圖區與縮圖列 -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左側：資料夾樹狀結構 -->
        <Border x:Name="LeftPanelBorder" Grid.Column="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,1,0">
            <TreeView x:Name="FolderTreeView" 
                      Margin="5" 
                      Background="Transparent" 
                      Foreground="#E0E0E0" 
                      FontFamily="Segoe UI, Segoe UI Emoji"
                      BorderThickness="0"
                      SelectedItemChanged="FolderTreeView_SelectedItemChanged">
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="2,4"/>
                    </Style>
                </TreeView.Resources>
            </TreeView>
        </Border>

        <!-- 垂直分割線，可拖曳調整左側寬度 -->
        <GridSplitter x:Name="VerticalSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#3E3E42" />

        <!-- 右側面板 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition x:Name="SplitterRowDef" Height="5" />
                <RowDefinition x:Name="BottomRowDef" Height="180" />
            </Grid.RowDefinitions>

            <!-- 主要圖片顯示區 (支援滾輪切換與縮放) -->
            <Grid x:Name="MainImageGrid" Grid.Row="0" Margin="10">
                <Border x:Name="MainImageBorder" Background="#121212" CornerRadius="8" ClipToBounds="True">
                    <ScrollViewer x:Name="MainImageScrollViewer" 
                                  HorizontalScrollBarVisibility="Hidden" 
                                  VerticalScrollBarVisibility="Hidden" 
                                  PreviewMouseWheel="MainImageScrollViewer_PreviewMouseWheel"
                                  PreviewMouseDown="MainImageScrollViewer_PreviewMouseDown"
                                  PreviewMouseMove="MainImageScrollViewer_PreviewMouseMove"
                                  PreviewMouseUp="MainImageScrollViewer_PreviewMouseUp"
                                  ScrollChanged="MainImageScrollViewer_ScrollChanged"
                                  PreviewMouseLeftButtonDown="MainImageScrollViewer_PreviewMouseLeftButtonDown">
                        <Image x:Name="MainImageView" 
                               Stretch="Uniform" 
                               StretchDirection="DownOnly" 
                               MaxWidth="{Binding ViewportWidth, ElementName=MainImageScrollViewer}"
                               MaxHeight="{Binding ViewportHeight, ElementName=MainImageScrollViewer}"
                               Margin="5">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="MainImageScale" ScaleX="1" ScaleY="1" />
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Border>
                
                <!-- 導覽圖 (Minimap) 浮在右上角 -->
                <Border x:Name="MinimapBorder" Width="200" Height="150" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" Background="#AA000000" CornerRadius="5" BorderBrush="#555" BorderThickness="1" Opacity="0" IsHitTestVisible="False">
                    <Grid Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="MinimapImage" Stretch="Uniform" />
                        <Canvas x:Name="MinimapCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Border x:Name="MinimapViewportRect" BorderBrush="#00AAFF" BorderThickness="2" Background="#3300AAFF" />
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>

            <!-- 水平分割線，可拖曳調整下方縮圖區高度 -->
            <GridSplitter x:Name="HorizontalSplitter" Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#3E3E42" />

            <!-- 下方：縮圖列表區 -->
            <Border x:Name="BottomPanelBorder" Grid.Row="2" Background="#2D2D30" BorderBrush="#333" BorderThickness="0,1,0,0">
                <ListView x:Name="ThumbnailListView" 
                          Margin="5" 
                          Background="Transparent" 
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          SelectionChanged="ThumbnailListView_SelectionChanged"
                          PreviewMouseWheel="ThumbnailListView_PreviewMouseWheel">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 使用垂直方向排列的 WrapPanel，讓項目從左排到右再換行，但限制在單列捲動 -->
                            <WrapPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="5" Padding="5" Background="#3E3E42" CornerRadius="5">
                                <StackPanel Width="120">
                                    <Image Source="{Binding Thumbnail}" Width="110" Height="100" Stretch="Uniform" />
                                    <TextBlock Text="{Binding FileName}" 
                                               Margin="0,5,0,0"
                                               Foreground="#E0E0E0" 
                                               TextTrimming="CharacterEllipsis" 
                                               TextAlignment="Center" 
                                               ToolTip="{Binding FileName}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</DockPanel>
</Window>
