<Window x:Class="PicViewer.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title_FilterWindow}" Height="380" Width="430" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#28282B">
    <StackPanel Margin="20">
        <TextBlock Text="{DynamicResource Filter_Prompt}" Foreground="#E0E0E0" FontSize="14" Margin="0,0,0,15" FontWeight="SemiBold"/>
        
        <CheckBox x:Name="ChkJpg" Content="JPG / JPEG" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <CheckBox x:Name="ChkPng" Content="PNG" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <CheckBox x:Name="ChkBmp" Content="BMP" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <CheckBox x:Name="ChkGif" Content="GIF" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <CheckBox x:Name="ChkTiff" Content="TIF / TIFF" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <CheckBox x:Name="ChkIco" Content="ICO / Icon" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <CheckBox x:Name="ChkSvg" Content="SVG" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="{DynamicResource Btn_AssociateFiles}" Width="120" Height="35" Click="BtnAssociate_Click" Cursor="Hand" Background="#3E3E42" Foreground="White" BorderThickness="0" Margin="0,0,10,0" ToolTip="Associate image files with PicViewer" />
            <Button Content="{DynamicResource Btn_RemoveAssociation}" Width="120" Height="35" Click="BtnRemoveAssociate_Click" Cursor="Hand" Background="#AA3E3E" Foreground="White" BorderThickness="0" Margin="0,0,10,0" ToolTip="Remove image file associations" />
            <Button Content="{DynamicResource Btn_ApplyAndSave}" Width="120" Height="35" Click="BtnOk_Click" Cursor="Hand" Background="#007ACC" Foreground="White" BorderThickness="0" />
        </StackPanel>
    </StackPanel>
</Window>
