<Window x:Class="PicViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title_SettingsWindow}" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#28282B" MinWidth="480">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Group 1: Filter -->
        <GroupBox Grid.Row="0" Grid.Column="0" Header="{DynamicResource Group_Filter}" Foreground="#E0E0E0" FontSize="14" Margin="0,0,15,15" BorderBrush="#555555" BorderThickness="1">
            <StackPanel Margin="10">
                <TextBlock Text="{DynamicResource Filter_Prompt}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                <UniformGrid Columns="3" VerticalAlignment="Top">
                    <CheckBox x:Name="ChkJpg" Content="JPG / JPEG" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkPng" Content="PNG" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkBmp" Content="BMP" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkGif" Content="GIF" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkTiff" Content="TIF / TIFF" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkIco" Content="ICO / Icon" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkSvg" Content="SVG" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkHeic" Content="HEIC" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                    <CheckBox x:Name="ChkWebp" Content="WEBP" Foreground="#E0E0E0" Margin="0,6,10,6" FontSize="14" Cursor="Hand"/>
                </UniformGrid>
            </StackPanel>
        </GroupBox>

        <!-- Group 2: Misc (Right Side) -->
        <GroupBox Grid.Row="0" Grid.Column="1" Header="{DynamicResource Group_Misc}" Foreground="#E0E0E0" FontSize="14" Margin="0,0,0,15" BorderBrush="#555555" BorderThickness="1" MinWidth="150">
            <StackPanel Margin="10">
                <CheckBox x:Name="ChkShowExif" Content="{DynamicResource Misc_ShowExif}" Foreground="#E0E0E0" Margin="0,6" FontSize="14" Cursor="Hand"/>
            </StackPanel>
        </GroupBox>

        <!-- Group 3: Association (Spans both columns) -->
        <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Header="{DynamicResource Group_Association}" Foreground="#E0E0E0" FontSize="14" BorderBrush="#555555" BorderThickness="1" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <TextBlock Text="{DynamicResource Assoc_Prompt}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtAssociationStatus" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnAssociate" Content="{DynamicResource Btn_AssociateFiles}" Width="140" Height="30" Click="BtnAssociate_Click" Cursor="Hand" Background="#3E3E42" Foreground="White" BorderThickness="0" Margin="0,0,10,0" ToolTip="Associate image files with PicViewer" />
                    <Button x:Name="BtnRemoveAssociate" Content="{DynamicResource Btn_RemoveAssociation}" Width="140" Height="30" Click="BtnRemoveAssociate_Click" Cursor="Hand" Background="#AA3E3E" Foreground="White" BorderThickness="0" ToolTip="Remove image file associations" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Apply and Save Button -->
        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="{DynamicResource Btn_ApplyAndSave}" Width="120" Height="30" Click="BtnOk_Click" Cursor="Hand" Background="#007ACC" Foreground="White" BorderThickness="0" HorizontalAlignment="Right" />

    </Grid>
</Window>
